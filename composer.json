{
    "name": "marnold-ebsco/phpfolioclient",
    "type": "library",
    "description": "Provides a PHP interface to FOLIO Library Systems Platform APIs",
    "require": {
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^13.0"
    },
	"autoload": {
        "psr-4": {
            "phpFolioClient\\": "src/folio/",
            "FolioConfig\\": "src/folio/",
            "FolioAuth\\": "src/folio/",
            "FolioLogger\\": "src/folio/",
            "FolioClient\\": "src/folio/",
            "FolioUtils\\": "src/folio/",
            "FolioInformation\\": "src/folio/",
            "FolioReferenceDataManager\\": "src/folio/",
            "FolioFileHandler\\": "src/folio/",
            "FolioDataExport\\": "src/folio/"
        },
        "classmap": [
            "src/"
        ]
    }
}
